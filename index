<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Launchpad — Move Out Budget Planner</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #13161e;
    --surface2: #1a1e2a;
    --border: #252a38;
    --accent: #e8ff5a;
    --accent2: #5af5c8;
    --accent3: #ff6b6b;
    --text: #eef0f6;
    --muted: #6b7280;
    --danger: #ff4757;
    --success: #2ed573;
    --warning: #ffa502;
    --radius: 14px;
    --font-head: 'Syne', sans-serif;
    --font-mono: 'DM Mono', monospace;
    --font-body: 'DM Sans', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background grain */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  /* HEADER */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13,15,20,0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    color: var(--accent);
  }
  .logo span { color: var(--text); }

  .header-actions { display: flex; gap: 0.75rem; align-items: center; }

  .btn {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.45rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    border: none;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { color: var(--text); border-color: var(--muted); }
  .btn-accent {
    background: var(--accent);
    color: #0d0f14;
    font-weight: 600;
  }
  .btn-accent:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-danger { background: rgba(255,71,87,0.15); color: var(--danger); border: 1px solid rgba(255,71,87,0.3); }
  .btn-danger:hover { background: rgba(255,71,87,0.25); }

  /* LAYOUT */
  main {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  /* HERO BANNER */
  .hero {
    background: linear-gradient(135deg, #1a1e2a 0%, #0f111a 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    animation: fadeUp 0.5s ease both;
  }
  .hero::after {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    background: radial-gradient(circle, rgba(232,255,90,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero h1 {
    font-family: var(--font-head);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }
  .hero h1 em { font-style: normal; color: var(--accent); }
  .hero p { color: var(--muted); font-size: 0.95rem; max-width: 480px; line-height: 1.6; }

  /* TABS */
  .tabs {
    display: flex;
    gap: 0.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.3rem;
    margin-bottom: 2rem;
    overflow-x: auto;
    animation: fadeUp 0.5s 0.1s ease both;
  }
  .tab-btn {
    flex: 1;
    min-width: 120px;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.6rem 1rem;
    border-radius: 7px;
    cursor: pointer;
    border: none;
    background: transparent;
    color: var(--muted);
    transition: all 0.15s;
    white-space: nowrap;
  }
  .tab-btn.active {
    background: var(--surface2);
    color: var(--text);
    box-shadow: 0 1px 4px rgba(0,0,0,0.3);
  }
  .tab-btn:hover:not(.active) { color: var(--text); }

  .tab-panel { display: none; animation: fadeUp 0.3s ease both; }
  .tab-panel.active { display: block; }

  /* CARDS */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .card-title {
    font-family: var(--font-head);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .card-title .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--accent);
    display: inline-block;
  }

  /* GRID LAYOUTS */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 700px) {
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
  }

  /* STAT BOXES */
  .stat-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .stat-box:hover { border-color: var(--muted); }
  .stat-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
    font-family: var(--font-mono);
  }
  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.7rem;
    font-weight: 500;
    letter-spacing: -0.02em;
  }
  .stat-value.green { color: var(--success); }
  .stat-value.red { color: var(--danger); }
  .stat-value.yellow { color: var(--accent); }
  .stat-sub { font-size: 0.75rem; color: var(--muted); margin-top: 0.3rem; }

  /* FORM ELEMENTS */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 0.75rem;
    align-items: end;
    margin-bottom: 0.75rem;
  }
  @media (max-width: 600px) { .form-row { grid-template-columns: 1fr 1fr; } }

  label {
    display: block;
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 0.35rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  input, select {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 0.85rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.15s;
    -webkit-appearance: none;
  }
  input:focus, select:focus { border-color: var(--accent); }
  input::placeholder { color: var(--muted); }
  select option { background: #1a1e2a; }

  .input-prefix-wrap { position: relative; }
  .input-prefix-wrap span {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    pointer-events: none;
  }
  .input-prefix-wrap input { padding-left: 1.6rem; }

  /* LINE ITEMS */
  .line-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    background: var(--surface2);
    margin-bottom: 0.5rem;
    gap: 1rem;
    animation: fadeUp 0.2s ease both;
  }
  .line-item-name {
    font-size: 0.88rem;
    flex: 1;
    color: var(--text);
  }
  .line-item-cat {
    font-size: 0.7rem;
    color: var(--muted);
    font-family: var(--font-mono);
    background: var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
  .line-item-amount {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
    min-width: 80px;
    text-align: right;
  }
  .line-item-del {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 1.1rem;
    padding: 0.1rem 0.2rem;
    line-height: 1;
    transition: color 0.15s;
    flex-shrink: 0;
  }
  .line-item-del:hover { color: var(--danger); }

  /* PROGRESS BAR */
  .progress-wrap { margin-top: 0.75rem; }
  .progress-label { display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--muted); margin-bottom: 0.4rem; font-family: var(--font-mono); }
  .progress-bar { height: 8px; background: var(--surface2); border-radius: 99px; overflow: hidden; }
  .progress-fill { height: 100%; border-radius: 99px; transition: width 0.4s cubic-bezier(0.4,0,0.2,1); }

  /* MILESTONE */
  .milestone-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-radius: 10px;
    background: var(--surface2);
    margin-bottom: 0.75rem;
    border: 1px solid var(--border);
    transition: border-color 0.2s;
  }
  .milestone-item.done { border-color: rgba(46,213,115,0.3); }
  .milestone-check {
    width: 28px; height: 28px;
    border-radius: 50%;
    border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem;
    flex-shrink: 0;
    transition: all 0.2s;
  }
  .milestone-item.done .milestone-check { background: var(--success); border-color: var(--success); color: #0d0f14; }
  .milestone-text { flex: 1; }
  .milestone-title { font-size: 0.88rem; font-weight: 500; }
  .milestone-desc { font-size: 0.75rem; color: var(--muted); margin-top: 0.15rem; }
  .milestone-amount { font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent); font-weight: 500; }

  /* TIMELINE */
  .timeline-card {
    background: var(--surface2);
    border-radius: 10px;
    padding: 1.25rem;
    border-left: 3px solid var(--accent);
    margin-bottom: 0.75rem;
  }
  .timeline-month {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .timeline-amount { font-family: var(--font-mono); font-size: 1.3rem; font-weight: 500; margin: 0.3rem 0; }
  .timeline-desc { font-size: 0.8rem; color: var(--muted); }

  /* RANGE SLIDER */
  .slider-row { display: flex; gap: 1rem; align-items: center; }
  input[type=range] {
    flex: 1;
    -webkit-appearance: none;
    background: var(--surface2);
    border: none;
    height: 6px;
    border-radius: 99px;
    padding: 0;
    cursor: pointer;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent);
  }
  .slider-val {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    min-width: 50px;
    text-align: right;
  }

  /* BADGE */
  .badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .badge-green { background: rgba(46,213,115,0.12); color: var(--success); }
  .badge-red { background: rgba(255,71,87,0.12); color: var(--danger); }
  .badge-yellow { background: rgba(232,255,90,0.12); color: var(--accent); }

  /* ALERT */
  .alert {
    padding: 0.9rem 1.1rem;
    border-radius: 10px;
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  .alert-warn { background: rgba(255,165,2,0.1); border: 1px solid rgba(255,165,2,0.3); color: var(--warning); }
  .alert-success { background: rgba(46,213,115,0.1); border: 1px solid rgba(46,213,115,0.3); color: var(--success); }
  .alert-info { background: rgba(90,245,200,0.08); border: 1px solid rgba(90,245,200,0.2); color: var(--accent2); }

  /* BREAKDOWN PIE (CSS only) */
  .pie-legend { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
  .pie-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: var(--muted); }
  .pie-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* DIVIDER */
  .divider { border: none; border-top: 1px solid var(--border); margin: 1.25rem 0; }

  /* TOTAL ROW */
  .total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 1rem;
    background: rgba(232,255,90,0.06);
    border: 1px solid rgba(232,255,90,0.2);
    border-radius: 8px;
    margin-top: 0.5rem;
  }
  .total-row .label { font-family: var(--font-head); font-weight: 700; font-size: 0.88rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .total-row .amount { font-family: var(--font-mono); font-size: 1.1rem; color: var(--accent); font-weight: 500; }

  /* SECTION HEADER */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1rem;
  }

  /* EMPTY STATE */
  .empty { text-align: center; padding: 2rem; color: var(--muted); font-size: 0.85rem; }
  .empty span { display: block; font-size: 2rem; margin-bottom: 0.5rem; }

  /* CHECKLIST */
  .checklist-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--surface2);
    border-radius: 8px;
    margin-bottom: 0.5rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .checklist-item:hover { background: #1f2435; }
  .checklist-item input[type=checkbox] {
    width: 16px; height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    cursor: pointer;
    accent-color: var(--accent);
    padding: 0;
    background: none;
    border: none;
  }
  .checklist-item .ci-text { flex: 1; }
  .checklist-item .ci-title { font-size: 0.88rem; }
  .checklist-item .ci-desc { font-size: 0.75rem; color: var(--muted); margin-top: 0.2rem; }
  .checklist-item.checked .ci-title { text-decoration: line-through; color: var(--muted); }
</style>
</head>
<body>

<header>
  <div class="logo">launch<span>pad</span></div>
  <div class="header-actions">
    <button class="btn btn-ghost" onclick="resetAll()">Reset</button>
    <button class="btn btn-accent" onclick="exportSummary()">Export Summary</button>
  </div>
</header>

<main>
  <div class="hero">
    <h1>Your plan to <em>get out</em><br>and get your own place.</h1>
    <p>Track income, map expenses, build your move-out fund, and see exactly how long until you can sign that lease.</p>
  </div>

  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('dashboard', this)">📊 Dashboard</button>
    <button class="tab-btn" onclick="switchTab('income', this)">💰 Income</button>
    <button class="tab-btn" onclick="switchTab('expenses', this)">🏠 Move-Out Costs</button>
    <button class="tab-btn" onclick="switchTab('monthly', this)">📅 Monthly Budget</button>
    <button class="tab-btn" onclick="switchTab('timeline', this)">🚀 Timeline</button>
    <button class="tab-btn" onclick="switchTab('checklist', this)">✅ Checklist</button>
  </div>

  <!-- DASHBOARD -->
  <div id="tab-dashboard" class="tab-panel active">
    <div class="grid-3" id="stat-boxes">
      <!-- rendered by JS -->
    </div>
    <div class="grid-2" style="margin-top:1.25rem">
      <div class="card">
        <div class="card-title"><span class="dot"></span> Monthly Cash Flow</div>
        <div id="cashflow-breakdown"></div>
      </div>
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--accent2)"></span> Move-Out Fund Progress</div>
        <div id="fund-progress"></div>
      </div>
    </div>
    <div class="card" style="margin-top:0">
      <div class="card-title"><span class="dot" style="background:var(--accent3)"></span> Readiness Check</div>
      <div id="readiness-check"></div>
    </div>
  </div>

  <!-- INCOME -->
  <div id="tab-income" class="tab-panel">
    <div class="card">
      <div class="card-title"><span class="dot"></span> Add Income Source</div>
      <div class="form-row">
        <div>
          <label>Source Name</label>
          <input id="inc-name" type="text" placeholder="e.g. Day job, Side hustle">
        </div>
        <div>
          <label>Monthly Amount</label>
          <div class="input-prefix-wrap">
            <span>$</span>
            <input id="inc-amount" type="number" placeholder="0" min="0">
          </div>
        </div>
        <button class="btn btn-accent" onclick="addIncome()" style="margin-bottom:0">+ Add</button>
      </div>
    </div>
    <div class="card">
      <div class="section-header">
        <div class="section-title">Your Income Sources</div>
        <div id="inc-total-badge"></div>
      </div>
      <div id="income-list"></div>
    </div>
    <div class="card">
      <div class="card-title"><span class="dot"></span> Monthly Savings Goal</div>
      <p style="font-size:0.82rem;color:var(--muted);margin-bottom:1rem;">What % of your income do you want to save each month toward your move-out fund?</p>
      <div class="slider-row">
        <input type="range" id="savings-pct" min="5" max="80" value="20" oninput="onSavingsPct(this.value)">
        <div class="slider-val" id="savings-pct-val">20%</div>
      </div>
      <div id="savings-pct-desc" style="margin-top:0.75rem;font-size:0.82rem;color:var(--muted);"></div>
    </div>
  </div>

  <!-- MOVE-OUT COSTS -->
  <div id="tab-expenses" class="tab-panel">
    <div class="alert alert-info">
      💡 These are your <strong>one-time</strong> upfront costs to move out — security deposit, first/last month's rent, furniture, movers, etc.
    </div>
    <div class="card">
      <div class="card-title"><span class="dot"></span> Add Move-Out Cost</div>
      <div class="form-row">
        <div>
          <label>Description</label>
          <input id="exp-name" type="text" placeholder="e.g. Security deposit">
        </div>
        <div>
          <label>Estimated Amount</label>
          <div class="input-prefix-wrap">
            <span>$</span>
            <input id="exp-amount" type="number" placeholder="0" min="0">
          </div>
        </div>
        <button class="btn btn-accent" onclick="addExpense()">+ Add</button>
      </div>
      <div style="margin-top:0.75rem">
        <label>Category</label>
        <select id="exp-cat">
          <option value="Housing">Housing (deposit, first/last month)</option>
          <option value="Movers">Moving & Transport</option>
          <option value="Furniture">Furniture & Appliances</option>
          <option value="Supplies">Household Supplies</option>
          <option value="Utilities">Utility Setup Fees</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>
    <div class="card">
      <div class="section-header">
        <div class="section-title">Move-Out Cost List</div>
        <div id="exp-total-badge"></div>
      </div>
      <div id="expense-list"></div>
    </div>
    <div class="card">
      <div class="card-title"><span class="dot"></span> Current Savings</div>
      <p style="font-size:0.82rem;color:var(--muted);margin-bottom:0.75rem;">How much have you already saved toward moving out?</p>
      <div class="input-prefix-wrap" style="max-width:240px">
        <span>$</span>
        <input id="current-savings" type="number" placeholder="0" min="0" value="0" oninput="save(); updateAll()">
      </div>
    </div>
  </div>

  <!-- MONTHLY BUDGET -->
  <div id="tab-monthly" class="tab-panel">
    <div class="alert alert-warn">
      ⚡ These are your <strong>recurring monthly</strong> costs once you move out. Be honest — this is what you'll pay every month.
    </div>
    <div class="card">
      <div class="card-title"><span class="dot"></span> Add Monthly Expense</div>
      <div class="form-row">
        <div>
          <label>Description</label>
          <input id="mexp-name" type="text" placeholder="e.g. Rent, Groceries">
        </div>
        <div>
          <label>Monthly Amount</label>
          <div class="input-prefix-wrap">
            <span>$</span>
            <input id="mexp-amount" type="number" placeholder="0" min="0">
          </div>
        </div>
        <button class="btn btn-accent" onclick="addMonthly()">+ Add</button>
      </div>
      <div style="margin-top:0.75rem">
        <label>Category</label>
        <select id="mexp-cat">
          <option value="Rent">Rent</option>
          <option value="Utilities">Utilities</option>
          <option value="Food">Food & Groceries</option>
          <option value="Transport">Transportation</option>
          <option value="Insurance">Insurance</option>
          <option value="Subscriptions">Subscriptions</option>
          <option value="Health">Health & Medical</option>
          <option value="Personal">Personal Care</option>
          <option value="Entertainment">Entertainment</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>
    <div class="card">
      <div class="section-header">
        <div class="section-title">Monthly Living Costs</div>
        <div id="mexp-total-badge"></div>
      </div>
      <div id="monthly-list"></div>
    </div>
  </div>

  <!-- TIMELINE -->
  <div id="tab-timeline" class="tab-panel">
    <div class="card">
      <div class="card-title"><span class="dot"></span> Your Move-Out Timeline</div>
      <div id="timeline-content"></div>
    </div>
    <div class="card">
      <div class="card-title"><span class="dot" style="background:var(--accent2)"></span> Emergency Fund Target</div>
      <p style="font-size:0.82rem;color:var(--muted);margin-bottom:1rem;">How many months of expenses should your emergency fund cover? (3–6 months recommended)</p>
      <div class="slider-row">
        <input type="range" id="emerg-months" min="1" max="12" value="3" oninput="onEmergMonths(this.value)">
        <div class="slider-val" id="emerg-months-val">3 mo</div>
      </div>
      <div id="emerg-desc" style="margin-top:0.75rem;font-size:0.82rem;color:var(--muted);"></div>
    </div>
  </div>

  <!-- CHECKLIST -->
  <div id="tab-checklist" class="tab-panel">
    <div class="card">
      <div class="card-title"><span class="dot"></span> Move-Out Checklist</div>
      <div id="checklist-list"></div>
    </div>
  </div>

</main>

<script>
// ─── STATE ───────────────────────────────────────────────────────────────────
const defaultState = {
  income: [],
  expenses: [],
  monthly: [],
  savingsPct: 20,
  currentSavings: 0,
  emergMonths: 3,
  checklist: {}
};

let state = JSON.parse(localStorage.getItem('launchpad_state') || 'null') || {...defaultState, income:[], expenses:[], monthly:[], checklist:{}};

function save() {
  state.currentSavings = parseFloat(document.getElementById('current-savings')?.value || 0) || 0;
  localStorage.setItem('launchpad_state', JSON.stringify(state));
}

// ─── CHECKLIST DATA ───────────────────────────────────────────────────────────
const CHECKLIST = [
  { id:'cl1', title:'Check your credit score', desc:'Landlords typically require 650+. Get a free report at annualcreditreport.com.' },
  { id:'cl2', title:'Research average rent in your target area', desc:'Use Zillow, Apartments.com, or Facebook Marketplace to gauge realistic costs.' },
  { id:'cl3', title:'Calculate your move-out fund goal', desc:'Security deposit + first/last month + setup costs (see Move-Out Costs tab).' },
  { id:'cl4', title:'Open a dedicated savings account', desc:'A separate high-yield savings account keeps your move-out fund untouched.' },
  { id:'cl5', title:'Set up automatic transfers', desc:'Auto-transfer your monthly savings on payday so you never skip.' },
  { id:'cl6', title:'Build 3–6 months emergency fund', desc:'Beyond your move-out costs — for emergencies after you move in.' },
  { id:'cl7', title:'Verify income requirement (3x rent rule)', desc:'Most landlords require income ≥ 3× monthly rent. Confirm you qualify.' },
  { id:'cl8', title:'Gather rental documents', desc:'Collect pay stubs, bank statements, ID, references, and employment letter.' },
  { id:'cl9', title:'Research renter\'s insurance', desc:'Usually $10–20/month. Often required, always worth it.' },
  { id:'cl10', title:'Account for utility startup costs', desc:'Electric, gas, water, internet — some require deposits for first-time renters.' },
  { id:'cl11', title:'Tour at least 3 apartments', desc:'Never sign a lease without seeing the unit in person.' },
  { id:'cl12', title:'Read the full lease before signing', desc:'Understand pet policies, subleasing rules, move-out notice requirements, etc.' },
];

// ─── TABS ─────────────────────────────────────────────────────────────────────
function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
  updateAll();
}

// ─── INCOME ───────────────────────────────────────────────────────────────────
function addIncome() {
  const name = document.getElementById('inc-name').value.trim();
  const amount = parseFloat(document.getElementById('inc-amount').value) || 0;
  if (!name || amount <= 0) { flash('inc-name', 'Please enter a name and amount'); return; }
  state.income.push({ id: Date.now(), name, amount });
  document.getElementById('inc-name').value = '';
  document.getElementById('inc-amount').value = '';
  save(); updateAll();
}

function removeIncome(id) {
  state.income = state.income.filter(i => i.id !== id);
  save(); updateAll();
}

function totalIncome() { return state.income.reduce((s,i) => s + i.amount, 0); }

// ─── MOVE-OUT EXPENSES ────────────────────────────────────────────────────────
function addExpense() {
  const name = document.getElementById('exp-name').value.trim();
  const amount = parseFloat(document.getElementById('exp-amount').value) || 0;
  const cat = document.getElementById('exp-cat').value;
  if (!name || amount <= 0) { flash('exp-name', 'Please enter a name and amount'); return; }
  state.expenses.push({ id: Date.now(), name, amount, cat });
  document.getElementById('exp-name').value = '';
  document.getElementById('exp-amount').value = '';
  save(); updateAll();
}

function removeExpense(id) {
  state.expenses = state.expenses.filter(e => e.id !== id);
  save(); updateAll();
}

function totalExpenses() { return state.expenses.reduce((s,e) => s + e.amount, 0); }

// ─── MONTHLY BUDGET ───────────────────────────────────────────────────────────
function addMonthly() {
  const name = document.getElementById('mexp-name').value.trim();
  const amount = parseFloat(document.getElementById('mexp-amount').value) || 0;
  const cat = document.getElementById('mexp-cat').value;
  if (!name || amount <= 0) { flash('mexp-name', 'Please enter a name and amount'); return; }
  state.monthly.push({ id: Date.now(), name, amount, cat });
  document.getElementById('mexp-name').value = '';
  document.getElementById('mexp-amount').value = '';
  save(); updateAll();
}

function removeMonthly(id) {
  state.monthly = state.monthly.filter(m => m.id !== id);
  save(); updateAll();
}

function totalMonthly() { return state.monthly.reduce((s,m) => s + m.amount, 0); }

// ─── SLIDERS ─────────────────────────────────────────────────────────────────
function onSavingsPct(v) {
  state.savingsPct = parseInt(v);
  document.getElementById('savings-pct-val').textContent = v + '%';
  save(); updateAll();
}

function onEmergMonths(v) {
  state.emergMonths = parseInt(v);
  document.getElementById('emerg-months-val').textContent = v + ' mo';
  save(); updateAll();
}

// ─── CHECKLIST ────────────────────────────────────────────────────────────────
function toggleCheck(id) {
  state.checklist[id] = !state.checklist[id];
  save(); renderChecklist();
}

function renderChecklist() {
  const el = document.getElementById('checklist-list');
  if (!el) return;
  const done = CHECKLIST.filter(c => state.checklist[c.id]).length;
  el.innerHTML = `
    <div style="margin-bottom:1rem">
      <div class="progress-label"><span>${done} / ${CHECKLIST.length} completed</span><span>${Math.round(done/CHECKLIST.length*100)}%</span></div>
      <div class="progress-bar"><div class="progress-fill" style="width:${done/CHECKLIST.length*100}%;background:var(--accent)"></div></div>
    </div>
    ${CHECKLIST.map(c => `
      <div class="checklist-item ${state.checklist[c.id]?'checked':''}" onclick="toggleCheck('${c.id}')">
        <input type="checkbox" ${state.checklist[c.id]?'checked':''} onclick="event.stopPropagation();toggleCheck('${c.id}')">
        <div class="ci-text">
          <div class="ci-title">${c.title}</div>
          <div class="ci-desc">${c.desc}</div>
        </div>
      </div>
    `).join('')}
  `;
}

// ─── RENDER HELPERS ───────────────────────────────────────────────────────────
function fmt(n) { return '$' + n.toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}); }

function renderList(containerId, items, removeFn) {
  const el = document.getElementById(containerId);
  if (!el) return;
  if (!items.length) {
    el.innerHTML = '<div class="empty"><span>📭</span>Nothing added yet.</div>';
    return;
  }
  el.innerHTML = items.map(it => `
    <div class="line-item">
      <div class="line-item-name">${it.name}</div>
      ${it.cat ? `<div class="line-item-cat">${it.cat}</div>` : ''}
      <div class="line-item-amount">${fmt(it.amount)}</div>
      <button class="line-item-del" onclick="${removeFn}(${it.id})" title="Remove">×</button>
    </div>
  `).join('');
}

function badge(n, label) {
  return `<span class="badge badge-yellow">${label}: ${fmt(n)}</span>`;
}

// ─── DASHBOARD ────────────────────────────────────────────────────────────────
function renderDashboard() {
  const inc = totalIncome();
  const exp = totalExpenses();
  const mon = totalMonthly();
  const sav = state.currentSavings || 0;
  const monthlySavings = inc * (state.savingsPct / 100);
  const freeCash = inc - mon - monthlySavings;
  const needed = Math.max(0, exp - sav);
  const monthsToGoal = monthlySavings > 0 ? Math.ceil(needed / monthlySavings) : Infinity;

  // Stat boxes
  const boxes = [
    { label:'Monthly Income', value: fmt(inc), cls: 'green', sub: `${state.income.length} source(s)` },
    { label:'Move-Out Goal', value: fmt(exp), cls: 'yellow', sub: `Saved: ${fmt(sav)}` },
    { label:'Monthly Living Cost', value: fmt(mon), cls: mon > inc ? 'red' : '', sub: mon > 0 ? `${Math.round(mon/inc*100)||0}% of income` : 'No data yet' },
  ];

  const sb = document.getElementById('stat-boxes');
  if (sb) sb.innerHTML = boxes.map(b => `
    <div class="stat-box">
      <div class="stat-label">${b.label}</div>
      <div class="stat-value ${b.cls}">${b.value}</div>
      <div class="stat-sub">${b.sub}</div>
    </div>
  `).join('');

  // Cash flow
  const cf = document.getElementById('cashflow-breakdown');
  if (cf) {
    const rows = [
      { label:'Monthly Income', amount: inc, color: 'var(--success)' },
      { label:`Savings (${state.savingsPct}%)`, amount: -monthlySavings, color: 'var(--accent)' },
      { label:'Monthly Expenses', amount: -mon, color: 'var(--danger)' },
    ];
    const surplus = inc - mon - monthlySavings;
    cf.innerHTML = rows.map(r => `
      <div style="display:flex;justify-content:space-between;padding:0.6rem 0;border-bottom:1px solid var(--border);font-size:0.88rem">
        <span style="color:var(--muted)">${r.label}</span>
        <span style="font-family:var(--font-mono);color:${r.color}">${r.amount >= 0 ? '+' : ''}${fmt(r.amount)}</span>
      </div>
    `).join('') + `
      <div class="total-row" style="margin-top:0.75rem">
        <div class="label">Monthly Surplus</div>
        <div class="amount" style="color:${surplus >= 0 ? 'var(--success)' : 'var(--danger)'}">${fmt(surplus)}</div>
      </div>
      ${surplus < 0 ? '<div class="alert alert-warn" style="margin-top:0.75rem;margin-bottom:0">⚠️ Your expenses + savings exceed income. Reduce spending or increase income.</div>' : ''}
    `;
  }

  // Fund progress
  const fp = document.getElementById('fund-progress');
  if (fp) {
    const pct = exp > 0 ? Math.min(100, (sav / exp) * 100) : 0;
    const color = pct >= 100 ? 'var(--success)' : pct >= 50 ? 'var(--accent)' : 'var(--accent3)';
    fp.innerHTML = `
      <div style="text-align:center;padding:1rem 0">
        <div style="font-family:var(--font-mono);font-size:2.2rem;font-weight:500;color:${color}">${Math.round(pct)}%</div>
        <div style="font-size:0.78rem;color:var(--muted);margin-top:0.3rem">${fmt(sav)} of ${fmt(exp)} goal</div>
      </div>
      <div class="progress-bar"><div class="progress-fill" style="width:${pct}%;background:${color}"></div></div>
      <div style="margin-top:1rem;font-size:0.82rem;color:var(--muted)">
        ${needed > 0 ? `Still need <strong style="color:var(--text)">${fmt(needed)}</strong> more.` : '<span style="color:var(--success)">🎉 Goal reached!</span>'}
        ${monthlySavings > 0 && needed > 0 ? ` At your current savings rate of <strong style="color:var(--accent)">${fmt(monthlySavings)}/mo</strong>, that's <strong style="color:var(--text)">${monthsToGoal} month${monthsToGoal===1?'':'s'}</strong>.` : ''}
      </div>
    `;
  }

  // Readiness
  const rc = document.getElementById('readiness-check');
  if (rc) {
    const checks = [
      { label: 'Income entered', ok: inc > 0 },
      { label: 'Move-out costs mapped', ok: exp > 0 },
      { label: 'Monthly budget planned', ok: mon > 0 },
      { label: 'Monthly expenses < income', ok: mon < inc && inc > 0 },
      { label: 'Positive cash flow after savings', ok: freeCash >= 0 && inc > 0 },
      { label: '3x rent rule (if rent entered)', ok: (() => { const rent = state.monthly.find(m => m.cat === 'Rent'); return rent ? inc >= rent.amount * 3 : true; })() },
    ];
    const score = checks.filter(c => c.ok).length;
    rc.innerHTML = `
      <div class="grid-2">
        ${checks.map(c => `
          <div style="display:flex;align-items:center;gap:0.6rem;font-size:0.84rem;padding:0.4rem 0">
            <span style="font-size:1rem">${c.ok ? '✅' : '⬜'}</span>
            <span style="color:${c.ok ? 'var(--text)' : 'var(--muted)'}">${c.label}</span>
          </div>
        `).join('')}
      </div>
      <div style="margin-top:1rem;padding:0.75rem 1rem;background:var(--surface2);border-radius:8px;font-size:0.85rem">
        Readiness score: <strong style="color:${score===6?'var(--success)':score>=4?'var(--accent)':'var(--accent3)'}">${score}/6</strong>
        ${score === 6 ? ' — You\'re ready to start hunting! 🚀' : score >= 4 ? ' — Getting close, keep it up!' : ' — More planning needed.'}
      </div>
    `;
  }
}

// ─── TIMELINE ─────────────────────────────────────────────────────────────────
function renderTimeline() {
  const el = document.getElementById('timeline-content');
  if (!el) return;

  const inc = totalIncome();
  const exp = totalExpenses();
  const mon = totalMonthly();
  const sav = state.currentSavings || 0;
  const monthlySavings = inc * (state.savingsPct / 100);
  const emergTarget = mon * state.emergMonths;
  const totalGoal = exp + emergTarget;
  const needed = Math.max(0, totalGoal - sav);
  const monthsToGoal = monthlySavings > 0 ? Math.ceil(needed / monthlySavings) : 0;

  document.getElementById('emerg-months-val').textContent = state.emergMonths + ' mo';
  document.getElementById('emerg-months').value = state.emergMonths;

  const ed = document.getElementById('emerg-desc');
  if (ed) ed.textContent = `Emergency fund target: ${fmt(emergTarget)} (${state.emergMonths} × ${fmt(mon)}/mo monthly expenses). Combined goal: ${fmt(totalGoal)}.`;

  if (inc === 0) {
    el.innerHTML = '<div class="alert alert-warn">Add your income on the Income tab to see your timeline.</div>';
    return;
  }
  if (exp === 0) {
    el.innerHTML = '<div class="alert alert-warn">Add move-out costs to see when you can move out.</div>';
    return;
  }

  const now = new Date();
  const months = Math.min(monthsToGoal, 36);
  let html = '';

  if (monthsToGoal === 0 && sav >= totalGoal) {
    html = '<div class="alert alert-success">🎉 You already have enough saved! You\'re ready to move out right now.</div>';
  } else if (monthlySavings <= 0) {
    html = '<div class="alert alert-warn">Set a savings percentage on the Income tab to generate a timeline.</div>';
  } else {
    // Key milestones
    const milestones = [];
    let balance = sav;
    for (let m = 1; m <= 36; m++) {
      balance += monthlySavings;
      if (balance >= exp && !milestones.find(x => x.key==='moveout')) {
        const d = new Date(now.getFullYear(), now.getMonth() + m, 1);
        milestones.push({ key:'moveout', month: m, date: d.toLocaleDateString('en-US',{month:'long',year:'numeric'}), amount: exp, label:'Move-Out Fund Reached 🏠', color:'var(--accent)' });
      }
      if (balance >= totalGoal && !milestones.find(x => x.key==='emerg')) {
        const d = new Date(now.getFullYear(), now.getMonth() + m, 1);
        milestones.push({ key:'emerg', month: m, date: d.toLocaleDateString('en-US',{month:'long',year:'numeric'}), amount: totalGoal, label:'Full Goal + Emergency Fund ✅', color:'var(--success)' });
        break;
      }
    }

    html += `<div style="margin-bottom:1.5rem">`;
    html += `<div style="font-size:0.82rem;color:var(--muted);margin-bottom:1rem">Saving ${fmt(monthlySavings)}/month (${state.savingsPct}% of ${fmt(inc)} income)</div>`;
    milestones.forEach(ms => {
      html += `
        <div class="timeline-card" style="border-left-color:${ms.color}">
          <div class="timeline-month">${ms.date} · Month ${ms.month}</div>
          <div class="timeline-amount" style="color:${ms.color}">${fmt(ms.amount)}</div>
          <div class="timeline-desc">${ms.label}</div>
        </div>
      `;
    });
    html += `</div>`;

    // Month-by-month projection (first 12)
    html += `<div style="font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted);margin-bottom:0.75rem;font-family:var(--font-mono)">Month-by-Month Projection</div>`;
    let bal = sav;
    for (let m = 1; m <= Math.min(monthsToGoal+1, 12); m++) {
      bal += monthlySavings;
      const pct = Math.min(100, (bal / totalGoal) * 100);
      const d = new Date(now.getFullYear(), now.getMonth() + m, 1);
      const label = d.toLocaleDateString('en-US',{month:'short',year:'numeric'});
      html += `
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.5rem;font-size:0.82rem">
          <div style="font-family:var(--font-mono);width:70px;color:var(--muted);flex-shrink:0">${label}</div>
          <div style="flex:1">
            <div class="progress-bar" style="height:6px"><div class="progress-fill" style="width:${pct}%;background:${bal>=totalGoal?'var(--success)':'var(--accent)'}"></div></div>
          </div>
          <div style="font-family:var(--font-mono);width:75px;text-align:right;color:${bal>=totalGoal?'var(--success)':'var(--text)'}">${fmt(bal)}</div>
        </div>
      `;
    }
  }
  el.innerHTML = html;
}

// ─── UPDATE ALL ───────────────────────────────────────────────────────────────
function updateAll() {
  // Sync slider values
  const sp = document.getElementById('savings-pct');
  if (sp) { sp.value = state.savingsPct; document.getElementById('savings-pct-val').textContent = state.savingsPct + '%'; }
  const em = document.getElementById('emerg-months');
  if (em) { em.value = state.emergMonths; }
  const cs = document.getElementById('current-savings');
  if (cs && parseFloat(cs.value) !== state.currentSavings) cs.value = state.currentSavings;

  // Savings desc
  const inc = totalIncome();
  const monthlySavings = inc * (state.savingsPct / 100);
  const sd = document.getElementById('savings-pct-desc');
  if (sd) sd.textContent = inc > 0 ? `At ${state.savingsPct}%, you'll save ${fmt(monthlySavings)}/month (${fmt(monthlySavings * 12)}/year).` : 'Add income above to see your monthly savings amount.';

  // Render all lists
  renderList('income-list', state.income, 'removeIncome');
  renderList('expense-list', state.expenses, 'removeExpense');
  renderList('monthly-list', state.monthly, 'removeMonthly');

  // Badges
  const ib = document.getElementById('inc-total-badge');
  if (ib) ib.innerHTML = badge(totalIncome(), 'Total');
  const eb = document.getElementById('exp-total-badge');
  if (eb) eb.innerHTML = badge(totalExpenses(), 'Total');
  const mb = document.getElementById('mexp-total-badge');
  if (mb) mb.innerHTML = badge(totalMonthly(), 'Total/mo');

  renderDashboard();
  renderTimeline();
  renderChecklist();
}

// ─── FLASH ────────────────────────────────────────────────────────────────────
function flash(id, msg) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.borderColor = 'var(--danger)';
  el.placeholder = msg;
  setTimeout(() => { el.style.borderColor = ''; el.placeholder = el.id.includes('name') ? 'e.g. ...' : '0'; }, 2000);
}

// ─── RESET ────────────────────────────────────────────────────────────────────
function resetAll() {
  if (!confirm('Reset all data? This cannot be undone.')) return;
  localStorage.removeItem('launchpad_state');
  state = {...defaultState, income:[], expenses:[], monthly:[], checklist:{}};
  document.getElementById('current-savings').value = 0;
  updateAll();
}

// ─── EXPORT ──────────────────────────────────────────────────────────────────
function exportSummary() {
  const inc = totalIncome();
  const exp = totalExpenses();
  const mon = totalMonthly();
  const sav = state.currentSavings || 0;
  const monthlySavings = inc * (state.savingsPct / 100);
  const needed = Math.max(0, exp - sav);
  const monthsToGoal = monthlySavings > 0 ? Math.ceil(needed / monthlySavings) : '?';

  let txt = `LAUNCHPAD — MOVE-OUT BUDGET SUMMARY\n${'='.repeat(40)}\n\n`;
  txt += `INCOME\n`;
  state.income.forEach(i => txt += `  ${i.name}: ${fmt(i.amount)}/mo\n`);
  txt += `  TOTAL: ${fmt(inc)}/mo\n\n`;
  txt += `MOVE-OUT COSTS (one-time)\n`;
  state.expenses.forEach(e => txt += `  [${e.cat}] ${e.name}: ${fmt(e.amount)}\n`);
  txt += `  TOTAL GOAL: ${fmt(exp)}\n  CURRENT SAVINGS: ${fmt(sav)}\n  STILL NEEDED: ${fmt(needed)}\n\n`;
  txt += `MONTHLY LIVING COSTS\n`;
  state.monthly.forEach(m => txt += `  [${m.cat}] ${m.name}: ${fmt(m.amount)}/mo\n`);
  txt += `  TOTAL: ${fmt(mon)}/mo\n\n`;
  txt += `SAVINGS PLAN\n  Savings rate: ${state.savingsPct}%\n  Monthly savings: ${fmt(monthlySavings)}\n  Months to goal: ${monthsToGoal}\n\n`;
  txt += `Generated: ${new Date().toLocaleDateString()}`;

  const blob = new Blob([txt], { type: 'text/plain' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'launchpad-budget-summary.txt';
  a.click();
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('current-savings').value = state.currentSavings || 0;
  document.getElementById('savings-pct').value = state.savingsPct;
  document.getElementById('emerg-months').value = state.emergMonths;
  updateAll();
});
</script>
</body>
</html>
